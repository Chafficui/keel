{
  "name": "keel",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/shared",
    "packages/email",
    "packages/frontend",
    "packages/backend"
  ],
  "scripts": {
    "dev": "npm run build:shared && npm run build:email && concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:email": "npm run dev -w packages/email",
    "build": "npm run build -w packages/shared && npm run build -w packages/email && npm run build --workspaces --if-present",
    "build:shared": "npm run build -w packages/shared",
    "build:email": "npm run build -w packages/email",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w packages/backend",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:push": "npm run db:push -w packages/backend",
    "db:studio": "npm run db:studio -w packages/backend",
    "cap:sync": "npm run cap:sync -w packages/frontend",
    "cap:ios": "npm run cap:ios -w packages/frontend",
    "cap:android": "npm run cap:android -w packages/frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  }
}
